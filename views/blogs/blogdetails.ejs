<%- include('../partials/head') %>
<body class="bg-light">

  <%- include('../partials/nav') %>

  <div class="container my-5">
      <div class="row justify-content-center">
          <div class="col-12 col-lg-8">

              <!-- Back link -->
              <a href="/" class="text-decoration-none text-secondary fw-semibold mb-4 d-inline-block">
                  <i class="ti ti-arrow-left"></i> Back to all blogs
              </a>

              <div class="card border border-light-subtle shadow-sm">
                  <div class="card-body p-4 p-md-5">

                      <span class="badge bg-primary-subtle text-primary mb-3 px-2 py-1 fw-semibold">Post</span>

                      <h1 class="fw-bold text-dark mb-3"><%= blog.title %></h1>

                      <p class="text-muted mb-4">
                          <i class="ti ti-calendar"></i>
                          <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                      </p>

                      <hr class="my-4 opacity-25">

                      <div class="text-dark fs-5" style="white-space: pre-line; line-height: 1.8;">
                          <%= blog.snippet %>
                      </div>

                  </div>
                  <% if(currentUser && currentUser === blog.author.toString()){ %>
                    <div class="card-footer bg-white border-top border-light-subtle p-4 d-flex justify-content-between">
                      <a href="/blogs/edit/<%= blog._id %>" class="btn btn-outline-secondary btn-sm px-3">
                          <i class="ti ti-edit"></i> Edit
                      </a>
                      <button class="btn btn-outline-danger btn-sm px-3 detail-delete-btn" data-id="<%= blog._id %>">
                          <i class="ti ti-trash"></i> Delete
                      </button>
                    </div>
                  <% } %>
                  
              </div>

          </div>
      </div>
  </div>

<script src="/js/script.js"></script>
</body>
</html>