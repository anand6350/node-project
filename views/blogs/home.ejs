<%- include('../partials/head') %>
<body class="bg-light">

  <%- include('../partials/nav') %>

  <div class="container my-5">
      <!-- Header -->
      <div class="mb-4">
          <h1 class="display-5 fw-bold text-dark">All blogs</h1>
          <p class="text-muted fs-5">Your published posts appear here.</p>
      </div>
      
      <hr class="my-4 opacity-25">
      
      <!-- Grid System -->
      <div class="row g-4">
          <% blogs.forEach(blog => { %>
          <div class="col-12 col-md-6 col-lg-4">
              <div class="card h-100 shadow-sm border border-light-subtle">
                  <div class="card-body d-flex flex-column p-4">
                      <span class="badge bg-primary-subtle text-primary align-self-start mb-3 px-2.5 py-1.5 fw-semibold">Post</span>
                      
                      <h5 class="card-title fw-bold text-dark mb-2"><%= blog.title %></h5>
                      <p class="card-text text-secondary mb-4 flex-grow-1"><%= blog.snippet %></p>
                      
                      <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light-subtle mt-auto">
                          <a href="/blogs/<%= blog._id %>" class="btn btn-link text-primary p-0 text-decoration-none fw-semibold">
                              View more →
                          </a>
                        <% if(currentUser && currentUser === blog.author.toString()){ %>
                          <button class="btn btn-outline-danger btn-sm px-3 delete-btn" data-id="<%= blog._id %>">
                              <i class="ti ti-trash"></i> Delete
                          </button>
                        <% } %>
                         
                      </div>
                  </div>
              </div>
          </div>
          <% }) %>
      </div>
  </div>
  
<script src="/js/script.js"></script>
</body>
</html>
